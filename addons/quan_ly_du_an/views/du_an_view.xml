<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_du_an_tree" model="ir.ui.view">
        <field name="name">du_an.tree</field>
        <field name="model">du_an</field>
        <field name="arch" type="xml">
            <tree string="Dự Án" 
                decoration-info="tien_do_du_an == 'chua_bat_dau'"
                decoration-success="tien_do_du_an == 'dang_thuc_hien'"
                decoration-muted="tien_do_du_an == 'hoan_thanh'"
                decoration-danger="tien_do_du_an == 'tam_dung'">
                <field name="ten_du_an"/>
                <field name="nguoi_phu_trach_id"/>
                <field name="ngay_bat_dau"/>
                <field name="ngay_ket_thuc"/>
                <field name="nhan_vien_ids" widget="many2many_tags"/>
                <field name="tien_do_du_an"/>
                <field name="tien_do" widget="progressbar"/>
                <field name="phan_tram_du_an" widget="progressbar"/>
            </tree>
        </field>
    </record>

    <record id="view_du_an_form" model="ir.ui.view">
        <field name="name">du_an.form</field>
        <field name="model">du_an</field>
        <field name="arch" type="xml">
            <form string="Dự Án">
                <header>
                    <!-- Nút Tạm dừng: hiển thị khi dự án đang thực hiện hoặc chưa bắt đầu -->
                    <button name="action_tam_dung_du_an" 
                            string="Tạm Dừng" 
                            type="object" 
                            class="oe_highlight"
                            attrs="{'invisible': ['|', ('tien_do_du_an', '=', 'tam_dung'), ('tien_do_du_an', '=', 'hoan_thanh')]}"/>
                    
                    <!-- Nút Tiếp tục: chỉ hiển thị khi dự án đang tạm dừng -->
                    <button name="action_tiep_tuc_du_an" 
                            string="Tiếp Tục" 
                            type="object" 
                            class="btn-success"
                            attrs="{'invisible': [('tien_do_du_an', '!=', 'tam_dung')]}"/>
                    
                    <!-- Trạng thái: chỉnh được khi tắt "Tự động cập nhật trạng thái" hoặc dùng nút Tạm dừng / Tiếp tục -->
                    <field name="tien_do_du_an" widget="statusbar" 
                           statusbar_visible="chua_bat_dau,dang_thuc_hien,hoan_thanh,tam_dung"
                           attrs="{'readonly': [('tu_dong_trang_thai_du_an', '=', True)]}"/>
                </header>
                <sheet>
                    <group col="4">
                        <field name="ten_du_an"/>
                        <field name="mo_ta" placeholder="Mô tả chi tiết về dự án..."/>
                        <field name="nguoi_phu_trach_id"/>
                        <field name="nhan_vien_ids" widget="many2many_tags"/>
                    </group>
                    <group col="4" string="Thời Gian Dự Án">
                        <field name="ngay_bat_dau" required="1"/>
                        <field name="ngay_ket_thuc"/>
                    </group>
                    <group col="4" string="Tiến Độ">
                        <field name="tu_dong_trang_thai_du_an"/>
                        <field name="tien_do" widget="progressbar" readonly="1"
                               string="Tiến Độ (% theo công việc hoàn thành)"/>
                        <field name="phan_tram_du_an" widget="progressbar"
                               string="Tiến Độ Dự Án (% có thể chỉnh tay)"/>
                        <field name="diem_tb_danh_gia" readonly="1" string="Điểm TB đánh giá (1–10)"/>
                    </group>

                    <notebook>
                        <page string="Tài Nguyên">
                            <field name="tai_nguyen_ids" context="{'default_du_an_id': active_id}">
                                <tree editable="bottom">
                                    <field name="ten_tai_nguyen"/>
                                    <field name="so_luong"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Danh Sách Rủi Ro">
                            <field name="rui_ro_ids" context="{'default_du_an_id': active_id}">
                                <tree editable="bottom">
                                    <field name="ten_rui_ro"/>
                                    <field name="muc_do_nghiem_trong"/>
                                    <field name="trang_thai"/>
                                    <field name="nguoi_chiu_trach_nhiem_id"/>
                                    <field name="bien_phap_xu_ly" optional="hide"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Tài Liệu Biểu Mẫu">
                            <field name="tai_lieu_mau_ids" context="{'default_du_an_id': active_id}">
                                <tree string="Biểu mẫu gắn dự án" editable="bottom">
                                    <field name="ten_tai_lieu"/>
                                    <field name="ngay_tai_len"/>
                                    <field name="file_dinh_kem" filename="ten_file" widget="binary"/>
                                    <field name="ten_file" invisible="1"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Đánh Giá Dự Án">
                            <field name="danh_gia_du_an_ids" context="{'default_du_an_id': active_id}">
                                <tree string="Đánh giá" editable="bottom">
                                    <field name="ten_dot_danh_gia"/>
                                    <field name="nguoi_danh_gia_id"
                                           domain="['|', ('id', 'in', parent.nhan_vien_ids), ('id', '=', parent.nguoi_phu_trach_id)]"
                                           options="{'no_create': True}"/>
                                    <field name="ngay_danh_gia"/>
                                    <field name="diem_so"/>
                                    <field name="nhan_xet" optional="show"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_du_an_graph" model="ir.ui.view">
        <field name="name">du_an.graph</field>
        <field name="model">du_an</field>
        <field name="arch" type="xml">
            <graph string="Tiến Độ Dự Án" type="bar">
                <field name="ten_du_an" type="row"/>
                <field name="phan_tram_du_an" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_du_an" model="ir.actions.act_window">
        <field name="name">Dự Án</field>
        <field name="res_model">du_an</field>
        <field name="view_mode">tree,form,graph</field>
    </record>
</odoo>


