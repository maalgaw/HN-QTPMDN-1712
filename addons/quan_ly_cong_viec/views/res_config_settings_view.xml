<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_quan_ly_cong_viec" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.quan_ly_cong_viec</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="inside">
                <div class="app_settings_block" data-string="AI (Quản lý công việc)" string="AI (Quản lý công việc)" data-key="quan_ly_cong_viec">
                    <h2>Cấu hình AI cho Quản lý công việc</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="qlcv_ai_enabled"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="qlcv_ai_enabled" string="Bật AI"/>
                                <div class="text-muted">
                                    Gợi ý nhân sự và viết mô tả công việc (Gemini). Tách biệt với cấu hình AI của module Quản lý dự án.
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box" attrs="{'invisible': [('qlcv_ai_enabled', '=', False)]}">
                            <div class="o_setting_right_pane">
                                <label for="qlcv_ai_api_key" string="API Key"/>
                                <field name="qlcv_ai_api_key" placeholder="AIza..."/>
                                <div class="text-muted">
                                    Lấy API key tại: https://aistudio.google.com/apikey
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box" attrs="{'invisible': [('qlcv_ai_enabled', '=', False)]}">
                            <div class="o_setting_right_pane">
                                <label for="qlcv_ai_base_url" string="Base URL"/>
                                <field name="qlcv_ai_base_url"/>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box" attrs="{'invisible': [('qlcv_ai_enabled', '=', False)]}">
                            <div class="o_setting_right_pane">
                                <label for="qlcv_ai_model" string="Model"/>
                                <field name="qlcv_ai_model" placeholder="gemini-2.5-flash"/>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box" attrs="{'invisible': [('qlcv_ai_enabled', '=', False)]}">
                            <div class="o_setting_right_pane">
                                <label for="qlcv_ai_timeout" string="Timeout (giây)"/>
                                <field name="qlcv_ai_timeout"/>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
