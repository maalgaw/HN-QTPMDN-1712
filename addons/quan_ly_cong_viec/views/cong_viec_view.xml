<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_cong_viec_tree" model="ir.ui.view">
        <field name="name">cong_viec.tree</field>
        <field name="model">cong_viec</field>
        <field name="arch" type="xml">
            <tree string="Công Việc Dự Án"
                decoration-success="trang_thai_cong_viec == 'hoan_thanh'"
                decoration-danger="tre_han == True">
                <field name="sequence" widget="handle" optional="hide"/>
                <field name="ten_cong_viec" string="Tên Công Việc"/>
                <field name="project_id" string="Dự Án"/>
                <field name="nguoi_thuc_hien_id" string="Người thực hiện"/>
                <field name="muc_do_uu_tien" string="Ưu tiên" optional="show"/>
                <field name="nhan_vien_ids" widget="many2many_tags"/>
                <field name="han_chot" string="Hạn Chót" widget="datetime"/>
                <field name="giai_doan_id" string="Giai Đoạn"/>
                <field name="phan_tram_cong_viec" widget="progressbar"/>
                <field name="trang_thai" string="Workflow"/>
                <field name="trang_thai_cong_viec"/>
                <field name="tre_han" optional="hide"/>
                <field name="du_dieu_kien_tien_quyet" string="Đủ tiên quyết" optional="hide"/>
                <field name="thoi_gian_con_lai" string="Ngày Còn"/>
            </tree>
        </field>
    </record>

    <record id="view_cong_viec_form" model="ir.ui.view">
        <field name="name">cong_viec.form</field>
        <field name="model">cong_viec</field>
        <field name="arch" type="xml">
            <form string="Công Việc Của Nhân Viên">
                <header>
                    <button name="action_ai_viet_mo_ta" type="object" string="AI viết mô tả"
                            class="btn-primary" attrs="{'invisible': [('ai_enabled', '=', False)]}"/>
                    <button name="action_ai_goi_y_nhan_su" type="object" string="AI gợi ý nhân sự"
                            class="btn-secondary" attrs="{'invisible': [('ai_enabled', '=', False)]}"/>
                </header>
                <sheet>
                    <field name="ai_enabled" invisible="1"/>
                    <group>
                        <group/>
                        <group>
                            <field name="tong_gio_lam" widget="float_time" readonly="1" string="Tổng Giờ Làm"/>
                        </group>
                    </group>
                    <group col="4">
                        <field name="sequence"/>
                        <field name="ten_cong_viec" string="Tên Công Việc"/>
                        <field name="project_id" string="Dự Án"/>
                        <field name="nguoi_thuc_hien_id" string="Người thực hiện"
                               domain="[('id', 'in', nhan_vien_ids)]"
                               options="{'no_create': True}"/>
                        <field name="muc_do_uu_tien" string="Ưu tiên"/>
                        <field name="nhan_vien_ids" widget="many2many_tags"/>
                        <field name="han_chot" string="Hạn Chót" widget="datetime"/>
                        <field name="giai_doan_id" string="Giai Đoạn"
                               domain="[('du_an_id', '=', project_id)]"
                               attrs="{'readonly': [('project_id', '=', False)]}"/>
                    </group>
                    <group col="4" string="Tiến Độ &amp; Trạng Thái">
                        <field name="trang_thai" string="Trạng Thái"/>
                        <field name="phan_tram_cong_viec" widget="progressbar" readonly="1"/>
                        <field name="trang_thai_cong_viec" readonly="1"/>
                        <field name="tre_han" readonly="1"/>
                        <field name="thoi_gian_con_lai" string="Ngày Còn" readonly="1"/>
                    </group>
                    <group string="Tiên quyết (mới) — điều kiện trước khi &quot;Đang làm&quot;" col="4">
                        <field name="du_dieu_kien_tien_quyet" readonly="1"/>
                        <field name="so_tien_quyet_chua_xong" readonly="1"/>
                        <field name="so_cong_viec_chi_doi_nay" readonly="1"/>
                    </group>
                    <group>
                        <field name="mo_ta" string="Mô Tả Công Việc" colspan="2" widget="html"/>
                    </group>
                    <group attrs="{'invisible': [('ai_last_note', '=', False)]}">
                        <field name="ai_last_note" string="Ghi chú AI" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Tiên quyết &amp; phụ thuộc">
                            <div class="text-muted mb-2">
                                Khai báo các công việc khác trong cùng dự án phải hoàn thành trước.
                                Hệ thống chặn chuyển trạng thái sang &quot;Đang làm&quot; nếu còn tiên quyết chưa xong, và không cho tạo vòng phụ thuộc.
                            </div>
                            <field name="phu_thuoc_tien_quyet_line_ids" nolabel="1"
                                   context="{'default_cong_viec_id': active_id}">
                                <tree string="Tiên quyết" editable="bottom">
                                    <field name="cong_viec_id" invisible="1"/>
                                    <field name="tien_quyet_id" string="Phải hoàn thành trước"
                                           domain="[('project_id', '=', parent.project_id), ('id', '!=', parent.id)]"
                                           options="{'no_create': True}"/>
                                    <field name="ghi_chu"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Nhật Ký Công Việc">
                            <field name="nhat_ky_cong_viec_ids">
                                <tree string="Nhật Ký Công Việc">
                                    <field name="nhan_vien_ids" string="Tên Nhân Viên" widget="many2many_tags"/>
                                    <field name="ngay_thuc_hien" string="Ngày Thực Hiện"/>
                                    <field name="muc_do" string="Mức Độ Hoàn Thành"/>
                                </tree>
                            </field>
                        </page>

                        <page string="Ghi nhận thời gian">
                            <field name="nhat_ky_thoi_gian_ids" context="{'default_cong_viec_id': active_id}">
                                <tree string="Timesheet" editable="bottom">
                                    <field name="ngay_thuc_hien"/>
                                    <field name="mo_ta"/>
                                    <field name="so_gio" widget="float_time"/>
                                    <field name="nhan_vien_id"
                                           domain="[('id', 'in', parent.nhan_vien_ids)]"
                                           options="{'no_create': True}"/>
                                </tree>
                            </field>
                        </page>

                        <page string="Tài Nguyên Sử Dụng">
                            <field name="tai_nguyen_cong_viec_ids">
                                <tree string="Tài Nguyên" editable="bottom">
                                    <field name="tai_nguyen_id" string="Tài Nguyên" 
                                           domain="[('du_an_id', '=', parent.project_id)]"
                                           options="{'no_create': True}"
                                           widget="many2one"/>
                                    <field name="so_luong_su_dung" string="Số Lượng Sử Dụng"/>
                                </tree>
                            </field>
                        </page>

                        <page string="Đánh Giá Nhân Viên">
                            <field name="danh_gia_nhan_vien_ids" mode="tree">
                            <tree>
                                <field name="nhan_vien_id" string="Nhân Viên"/>
                                <field name="diem_so" string="Điểm Số"/>
                                <field name="nhan_xet" string="Nhận Xét"/>
                                <field name="ngay_danh_gia" string="Ngày Đánh Giá"/>
                            </tree>
                            </field>
                        </page>

                        <page string="Tài liệu đính kèm">
                            <field name="tai_lieu_dinh_kem_ids" context="{'default_cong_viec_id': active_id}">
                                <tree string="Tài liệu" editable="bottom">
                                    <field name="ten_tai_lieu"/>
                                    <field name="ngay_tai_len"/>
                                    <field name="nguoi_tai_len_id"/>
                                    <field name="file_dinh_kem" filename="ten_file" widget="binary"/>
                                    <field name="ten_file" invisible="1"/>
                                    <field name="link_luu_tru_ngoai" optional="hide"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_cong_viec_search" model="ir.ui.view">
        <field name="name">cong_viec.search</field>
        <field name="model">cong_viec</field>
        <field name="arch" type="xml">
            <search string="Tìm Kiếm Công Việc">
                <field name="ten_cong_viec" string="Tên Công Việc"/>
                <field name="project_id" string="Dự Án"/>
                <field name="nguoi_thuc_hien_id" string="Người thực hiện"/>
                <field name="trang_thai_cong_viec" string="Trạng Thái"/>
                <filter string="Hoàn Thành" name="hoan_thanh" domain="[('trang_thai_cong_viec', '=', 'hoan_thanh')]"/>
                <filter string="Chưa Hoàn Thành" name="chua_hoan_thanh" domain="[('trang_thai_cong_viec', '=', 'chua_hoan_thanh')]"/>
                <filter string="Ưu tiên cao trở lên" name="uu_tien_cao" domain="[('muc_do_uu_tien', 'in', ('2', '3'))]"/>
                <group expand="0" string="Nhóm">
                    <filter string="Trạng thái workflow" name="group_trang_thai" context="{'group_by': 'trang_thai'}"/>
                    <filter string="Dự án" name="group_du_an" context="{'group_by': 'project_id'}"/>
                    <filter string="Người thực hiện" name="group_nguoi_th" context="{'group_by': 'nguoi_thuc_hien_id'}"/>
                    <filter string="Ưu tiên" name="group_uu_tien" context="{'group_by': 'muc_do_uu_tien'}"/>
                </group>
                <searchpanel>
                    <field name="project_id" string="Dự Án" select="multi"/>
                    <field name="giai_doan_id" string="Giai Đoạn" select="multi"/>
                </searchpanel>
            </search>
        </field>
    </record>

    <record id="view_cong_viec_kanban" model="ir.ui.view">
        <field name="name">cong_viec.kanban</field>
        <field name="model">cong_viec</field>
        <field name="arch" type="xml">
            <kanban default_group_by="trang_thai" class="o_kanban_small_column">
                <field name="ten_cong_viec"/>
                <field name="project_id"/>
                <field name="phan_tram_cong_viec"/>
                <field name="han_chot"/>
                <field name="muc_do_uu_tien"/>
                <field name="tre_han"/>
                <field name="nguoi_thuc_hien_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_record_top mb-1">
                                <strong class="o_kanban_record_title"><field name="ten_cong_viec"/></strong>
                            </div>
                            <div class="text-muted small">
                                <field name="project_id"/>
                            </div>
                            <div class="mt-2">
                                <field name="phan_tram_cong_viec" widget="progressbar"/>
                            </div>
                            <div class="mt-1 small">
                                <span>Hạn: </span><field name="han_chot" widget="datetime"/>
                            </div>
                            <div class="mt-1">
                                <field name="nguoi_thuc_hien_id"/>
                            </div>
                            <div class="mt-1 small text-danger" t-if="record.tre_han.raw_value">Quá hạn</div>
                            <div class="mt-1 small text-warning" t-if="record.muc_do_uu_tien.raw_value == '3'">Khẩn cấp</div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_cong_viec" model="ir.actions.act_window">
        <field name="name">Công Việc Của Nhân Viên</field>
        <field name="res_model">cong_viec</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="search_view_id" ref="view_cong_viec_search"/>
        <field name="context">{'search_default_chua_hoan_thanh': 1}</field>
    </record>
</odoo>
